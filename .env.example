# ── Database ────────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/fraudlens
SPRING_DATASOURCE_USERNAME=fraudlens
SPRING_DATASOURCE_PASSWORD=fraudlens

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Must be at least 256 bits (32 chars). Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-256-bit-secret-at-least-32-chars
JWT_EXPIRATION_MS=3600000

# ── AI (Anthropic) ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── CORS ────────────────────────────────────────────────────────────────────────
# Docker Compose: frontend nginx is on port 3000 → use http://localhost:3000
# Local dev (npm run dev): Vite runs on port 5173 → change to http://localhost:5173
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ── Admin user seed ─────────────────────────────────────────────────────────────
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123

# ── Actuator (optional — defaults to main port 8080 if not set) ─────────────────
# MANAGEMENT_PORT=8081
